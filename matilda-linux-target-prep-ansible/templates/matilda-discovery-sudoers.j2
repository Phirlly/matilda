/usr/bin/uptime, /usr/sbin/uptime, /bin/uptime, /sbin/uptime, \
/usr/sbin/psrinfo, /usr/sbin/prtconf, /usr/sbin/prtdiag, /usr/sbin/isainfo, /usr/sbin/sysdef, \
/usr/sbin/lsconf, /usr/sbin/lsuser, \
/usr/bin/find, /usr/sbin/find, /bin/find, /sbin/find, \
/usr/bin/cat, /usr/sbin/cat, /bin/cat, /sbin/cat, \
/usr/bin/readlink, /usr/sbin/readlink, /bin/readlink, /sbin/readlink, \
/usr/bin/pwdx, /usr/sbin/pwdx, /bin/pwdx, /sbin/pwdx, \
