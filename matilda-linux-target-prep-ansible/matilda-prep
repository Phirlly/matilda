#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

show_help() {
  cat <<'EOF'
Matilda Linux Target Prep

Usage:
  ./matilda-prep <command>

Commands:
  help        Show this help message
  preflight   Run read-only preflight checks
  setup       Configure Linux targets for Matilda Discovery
  apply       Alias for setup
  validate    Validate targets are ready for Matilda Discovery
  run         Run preflight, setup, and validate in order

Recommended workflow:
  ./matilda-prep preflight
  ./matilda-prep setup
  ./matilda-prep validate

One-shot lab workflow:
  ./matilda-prep run

Notes:
  - preflight is read-only
  - setup modifies target VMs and asks for confirmation
  - apply is an alias for setup
  - validate writes reports under reports/
  - inventory.yml is local-only and ignored by git
EOF
}

run_preflight() {
  "${SCRIPT_DIR}/scripts/run-preflight.sh"
}

run_setup() {
  "${SCRIPT_DIR}/scripts/run-setup.sh"
}

run_validate() {
  "${SCRIPT_DIR}/scripts/run-validate.sh"
}

run_all() {
  echo "============================================================"
  echo "Matilda Linux Target Prep - RUN"
  echo "Workflow: preflight -> setup -> validate"
  echo "============================================================"
  echo
  echo "Step 1 of 3: Preflight"
  run_preflight

  echo
  echo "Step 2 of 3: Setup"
  echo "Setup modifies target VMs and will ask for confirmation."
  run_setup

  echo
  echo "Step 3 of 3: Validate"
  run_validate

  echo
  echo "Run complete. Use reports/validated-discovery-ips.txt in Matilda Network Discovery."
}

COMMAND="${1:-help}"

case "${COMMAND}" in
  help|-h|--help)
    show_help
    ;;
  preflight)
    run_preflight
    ;;
  setup|apply)
    run_setup
    ;;
  validate)
    run_validate
    ;;
  run)
    run_all
    ;;
  *)
    echo "ERROR: Unknown command: ${COMMAND}" >&2
    echo >&2
    show_help >&2
    exit 1
    ;;
esac
