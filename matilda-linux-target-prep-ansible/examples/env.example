# Optional convenience file.
# Copy this to .env if you do not want to type prompts every time.
# Do not commit .env with real environment details.

TARGET_ADMIN_USER=<target-admin-user>
TARGET_ADMIN_PRIVATE_KEY_FILE=/path/to/target-admin-private-key

MATILDA_PROBE_ANSIBLE_HOST=<probe-public-ip-or-hostname>
MATILDA_PROBE_USER=<probe-admin-user>
MATILDA_PROBE_ADMIN_PRIVATE_KEY_FILE=/path/to/probe-admin-private-key

MATILDA_PUBLIC_KEY_FILE=/path/to/MatildaProbeKey.pem.pub
MATILDA_PROBE_PRIVATE_KEY_ON_PROBE=<discovery-private-key-path-on-probe>
