/usr/bin/dmesg, /usr/sbin/dmesg, /bin/dmesg, /sbin/dmesg, \
/usr/bin/lshw, /usr/sbin/lshw, /bin/lshw, /sbin/lshw, \
/usr/bin/lspci, /usr/sbin/lspci, /bin/lspci, /sbin/lspci, \
