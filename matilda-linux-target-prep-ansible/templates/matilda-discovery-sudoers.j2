/usr/bin/lvs, /usr/sbin/lvs, /bin/lvs, /sbin/lvs, \
/usr/sbin/lspv, /usr/sbin/lsvg, /usr/sbin/lslv, /usr/sbin/bootinfo, /usr/sbin/lsdev, \
/usr/sbin/format, /usr/sbin/luxadm, /usr/sbin/ioscan, /usr/sbin/diskinfo, \
