############################################################
# Matilda Cloud – Agentless Discovery Sudoers
# Service Account: {{ matilda_service_user }} | OS: Linux, AIX, Solaris, HP-UX
# Read-only, passwordless sudo for agentless infrastructure discovery
############################################################

############################
# User Definition
############################
User_Alias MATILDA_USER = {{ matilda_service_user }}
Defaults:MATILDA_USER !requiretty
Defaults:MATILDA_USER secure_path="/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"

############################################################
# MATILDA_DISCOVERY – Read-Only Commands
############################################################
Cmnd_Alias MATILDA_DISCOVERY = \
/usr/bin/ip, /usr/sbin/ip, /bin/ip, /sbin/ip, \
/usr/bin/ifconfig, /usr/sbin/ifconfig, /bin/ifconfig, /sbin/ifconfig, \
/usr/bin/route, /usr/sbin/route, /bin/route, /sbin/route, \
/usr/bin/netstat, /usr/sbin/netstat, /bin/netstat, /sbin/netstat, \
/usr/bin/ss, /usr/sbin/ss, /bin/ss, /sbin/ss, \
/usr/bin/arp, /usr/sbin/arp, /bin/arp, /sbin/arp, \
/usr/bin/ethtool, /usr/sbin/ethtool, /bin/ethtool, /sbin/ethtool, \
/usr/bin/tcpdump, /usr/sbin/tcpdump, /bin/tcpdump, /sbin/tcpdump, \
/usr/sbin/dladm, \
/usr/bin/enstat, /usr/sbin/enstat, /bin/enstat, /sbin/enstat, \
/usr/bin/lsblk, /usr/sbin/lsblk, /bin/lsblk, /sbin/lsblk, \
/usr/bin/blkid, /usr/sbin/blkid, /bin/blkid, /sbin/blkid, \
/usr/bin/findmnt, /usr/sbin/findmnt, /bin/findmnt, /sbin/findmnt, \
/usr/bin/df, /usr/sbin/df, /bin/df, /sbin/df, \
