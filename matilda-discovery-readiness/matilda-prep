#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
BINARY="${SCRIPT_DIR}/.bin/matilda-prep"

HAS_GO=0
if command -v go >/dev/null 2>&1; then
  HAS_GO=1
fi

if [[ -x "${BINARY}" && ( "${MATILDA_PREP_USE_BINARY:-}" == "1" || "${HAS_GO}" == "0" ) ]]; then
  exec "${BINARY}" "$@"
fi

if [[ "${HAS_GO}" == "0" ]]; then
  echo "ERROR: Go is required to run the Matilda Discovery Readiness CLI from source." >&2
  echo "Build once with: go build -o .bin/matilda-prep ./cmd/matilda-prep" >&2
  exit 1
fi

export GOCACHE="${GOCACHE:-${SCRIPT_DIR}/.gocache}"
mkdir -p "${SCRIPT_DIR}/.bin"
go build -o "${BINARY}" "${SCRIPT_DIR}/cmd/matilda-prep"
exec "${BINARY}" "$@"
